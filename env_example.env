# 帳密設定：此行為註解，# 開頭整行忽略；其餘一行一個 key=value（pin=自然人憑證PIN、sssh_account=校網帳號、sssh_password=校網密碼）
#pin是自然人憑證pin code
pin=000000
#sssh_account是松高校網密碼
sssh_account=abc
sssh_password=abc123
#sssh_publisher是上網公告表單「發布者」欄要填的名稱
sssh_publisher=系管師R
#sssh_publish_unit是上網公告表單「發布單位」下拉要選的單位(擇一,須與站上選項文字一致),如:圖書館/系管師群組/資訊媒體組
sssh_publish_unit=系管師群組
# env_example.env這是個範例，當填入上方的資料後，改名為env.env，記得別把這個檔案push 上github
